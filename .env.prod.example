# Production environment variables template
# Copy to .env.prod and fill in real values

SECRET_KEY=change-me-to-a-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Google AI
GOOGLE_API_KEY=your-production-gemini-api-key

# Database (overridden by docker-compose env, but needed for manage.py)
POSTGRES_USER=raguser
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ragchatbot
DATABASE_URL=postgres://raguser:changeme@db:5432/ragchatbot

# Redis
REDIS_URL=redis://redis:6379/0

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Django settings module
DJANGO_SETTINGS_MODULE=config.settings.base
