# Django
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgres://raguser:ragpassword@db:5432/ragchatbot

# Redis
REDIS_URL=redis://redis:6379/0

# LLM Provider Configuration
# Options: groq, gemini, openai, ollama
# Default: groq (fast, free, high quality)
LLM_PROVIDER=groq

# Groq Configuration (Get free API key at https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Google AI Configuration (fallback provider)
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI Configuration (works with Together AI, Groq using OpenAI API)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# Ollama Configuration (local, free)
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Configuration
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_API_KEY=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Frontend
VITE_API_URL=http://localhost:8000/api

# Chroma Data Directory
CHROMA_PERSIST_DIR=/.chroma_data
